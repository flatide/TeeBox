// Parallel tasks demo: multiple SHELL commands via multi/thread
// Submit with property: scriptsDir = /path/to/demo/teebox/scripts
PRINT("starting parallel tasks")

ctx = SHELL_CTX(scriptsDir)

function run_task(ctx, name) do
    return SHELL(::ctx, "./echo_done.sh " + name)
end

multi result do
    thread task1: run_task(::ctx, "task1")
    thread task2: run_task(::ctx, "task2")
end

PRINT("task1 result", result.task1)
PRINT("task2 result", result.task2)
