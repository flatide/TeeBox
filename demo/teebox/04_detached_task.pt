// Parallel tasks demo: multiple SHELL commands via multi/thread
PRINT("starting parallel tasks")

function run_task(ctx, name) do
    return SHELL("sh -c 'sleep 10; echo " + name + "_done'")
end

multi result do
    thread task1: run_task({}, "task1")
    thread task2: run_task({}, "task2")
end

PRINT("task1 result", result.task1)
PRINT("task2 result", result.task2)
